// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// defining the user roles for our app
enum UserRole {
  USER
  ADMIN
  PREMIUM_USER
}

// AI provider options available to the user
enum AiProvider {
  OLLAMA_LOCAL
  OLLAMA_REMOTE
  OPENAI
  GEMINI
  ANTHROPIC
  OPEN_ROUTER
}

// defining here the schema for our app
model User {
  id       String    @id @default(cuid()) @map("_id")
  name     String
  email    String    @unique
  image    String?
  accounts Account[]
  role     UserRole  @default(USER)

  // AI provider settings — key is stored AES-256-GCM encrypted, never in plaintext
  aiProvider      AiProvider? // which provider the user has configured
  encryptedApiKey String? // encrypted API key (OpenAI / Gemini / Anthropic / Ollama remote)
  ollamaBaseUrl   String? // only used when aiProvider = OLLAMA_REMOTE
  aiModel         String? // which model the user has configured (e.g., "gpt-4", "gemini-1.5", "claude-2")

  myplaground        Playground[]
  starMarkPlayground StarMark[]
  gitCommits         GitCommit[]

  creratedAt DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  shareLinks shareLink[]
}

// defining the schema for the accounts, which will be used for authentication and authorization in our app. It includes fields for the account type, provider, and tokens, as well as a relation to the User model.
model Account {
  id                String  @id @default(cuid()) @map("_id")
  userId            String  @map("userId")
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

// defining the templates that we will be using for our playgrounds. This enum will help us to easily manage and reference the different templates in our app.
enum Templates {
  REACT
  NEXTJS
  EXPRESS
  VUE
  HONO
  ANGULAR
}

// defining the schema for the playgrounds, which will be the main feature of our app. It includes fields for the title, description, code, template, and relations to the User and StarMark models. The template field uses the Templates enum to specify which template is being used for each playground.
model Playground {
  id          String      @id @default(cuid()) @map("_id")
  title       String
  description String
  code        String
  template    Templates   @default(REACT)
  gitCommits  GitCommit[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  starMark    StarMark[]
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  templateFile TemplateFile[]
  shareLinks   shareLink[]
}

// defining the schema for the star marks, which will allow users to mark their favorite playgrounds. It includes fields for the user ID, playground ID, and a boolean to indicate whether the playground is marked or not. It also includes relations to the User and Playground models, and unique constraints to ensure that a user can only mark a playground once.

model StarMark {
  id           String   @id @default(cuid()) @map("_id")
  userId       String
  playgroundId String
  isMarked     Boolean  @default(false)
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  playground Playground @relation(fields: [playgroundId], references: [id], onDelete: Cascade)

  @@unique([userId, playgroundId])
  @@index([userId])
  @@index([playgroundId])
}

// defining the schema for the template files, which will store the content of the templates used for the playgrounds. It includes fields for the content, created and updated timestamps, and a relation to the Playground model. The playgroundId field is unique to ensure that each playground has only one associated template file.

model TemplateFile {
  id           String     @id @default(cuid()) @map("_id")
  content      Json
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  playgroundId String     @unique
  playground   Playground @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
}

// defining the schema for the share links, which will allow users to share their playgrounds with others. It includes fields for the token, playground ID, permission level, creator ID, expiration date, revocation status, access count, and relations to the Playground and User models. The token field is unique to ensure that each share link has a unique identifier.
enum SharePermission {
  VIEW_ONLY
  VIEW_AND_EDIT
}

// defining the schema for the share link accesses, which will track the users who have accessed a shared playground. It includes fields for the share link ID, user ID, and created timestamp, as well as a relation to the shareLink model. The combination of shareLinkId and userId is unique to ensure that each user can only access a shared playground once.
model shareLink {
  id           String          @id @default(cuid()) @map("_id")
  token        String          @unique
  playgroundId String
  permission   SharePermission @default(VIEW_ONLY)
  createdById  String
  expiresAt    DateTime?
  isRevoked    Boolean         @default(false)
  accessCount  Int             @default(0)
  createdAt    DateTime        @default(now())

  playground Playground        @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  createdBy  User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  accesses   ShareLinkAccess[]

  @@index([playgroundId])
  @@index([createdById])
}

// defining the schema for the share link accesses, which will track the users who have accessed a shared playground. It includes fields for the share link ID, user ID, and created timestamp, as well as a relation to the shareLink model. The combination of shareLinkId and userId is unique to ensure that each user can only access a shared playground once.
model ShareLinkAccess {
  id          String    @id @default(cuid()) @map("_id")
  shareLink   shareLink @relation(fields: [shareLinkId], references: [id], onDelete: Cascade)
  shareLinkId String
  userId      String
  createdAt   DateTime  @default(now())

  @@unique([shareLinkId, userId])
}

// defining the schema for the git commits, which will allow users to save different versions of their playgrounds. It includes fields for the commit message, snapshot of the code, playground ID, author ID, and created timestamp. It also includes relations to the Playground and User models, and indexes on the playgroundId and authorId fields for efficient querying.
model GitCommit {
  id           String   @id @default(cuid()) @map("_id")
  message      String
  snapshot     Json
  playgroundId String
  authorId     String
  createdAt    DateTime @default(now())

  playground Playground @relation(fields: [playgroundId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([playgroundId])
  @@index([authorId])
}
