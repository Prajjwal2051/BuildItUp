// This is an example env file. Copy this to .env and fill in the values.

DATABASE_URL=

BETTER_AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

GITHUB_ID=
GITHUB_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=

# ── AI Provider Configuration ────────────────────────────────────────────────
# Optional: Dedicated secret for encrypting AI API keys at rest.
# If omitted, the app reuses AUTH_SECRET / NEXTAUTH_SECRET / BETTER_AUTH_SECRET.
# Generate with: openssl rand -base64 32
AI_SETTINGS_SECRET=

# Optional: Only needed if you want to support Ollama LOCAL mode (dev only).
# Not required when users provide their own keys via the AI Settings modal.
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Override the default Ollama model for local/remote mode.
# OLLAMA_MODEL=qwen2.5-coder:7b

SHARE_LINK_SECRET= # Generate with: openssl rand -base64 32

REDIS_URL= # e.g. redis://localhost:6379 or redis://:password@hostname:port

# ── Collaboration WebSocket Server ───────────────────────────────────────────
# URL of the CollabServer (WebSocket backend). Must be set in production or the
# client will fall back to localhost:4001, which will never work on Render/Vercel.
# Accepts http://, https://, ws://, or wss:// — http(s):// is auto-converted to ws(s)://.
# Example (Render): NEXT_PUBLIC_COLLAB_WS_URL=https://colabserver-bt3g.onrender.com
NEXT_PUBLIC_COLLAB_WS_URL=
