// This is an example env file. Copy this to .env and fill in the values.

DATABASE_URL=

BETTER_AUTH_SECRET=
NEXTAUTH_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
AUTH_URL=http://localhost:3000

GITHUB_ID=
GITHUB_SECRET=
GOOGLE_ID=
GOOGLE_SECRET=

# ── AI Provider Configuration ────────────────────────────────────────────────
# Required: A 32+ character random secret used to AES-256-GCM encrypt API keys at rest.
# Generate with: openssl rand -base64 32
AI_SETTINGS_SECRET=

# Optional: Only needed if you want to support Ollama LOCAL mode (dev only).
# Not required when users provide their own keys via the AI Settings modal.
OLLAMA_BASE_URL=http://localhost:11434

# Optional: Override the default Ollama model for local/remote mode.
# OLLAMA_MODEL=qwen2.5-coder:7b
